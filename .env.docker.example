# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.
#
#   cp .env.docker.example .env
#
# DJANGO_SETTINGS_MODULE is already set in Dockerfile to config.settings.production
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-50-char-random-string

DEBUG=False

# Comma-separated list — add your domain / server IP here
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=fileshare
DB_USER=fileshare
DB_PASSWORD=strongpasswordhere
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email ─────────────────────────────────────────────────────────────────────
# Use console backend while testing; switch to smtp for real delivery
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── IP Group settings ─────────────────────────────────────────────────────────
IP_GROUP_ENABLED=True
IP_GROUP_MAX_UPLOAD_MB=50
IP_GROUP_RATE_LIMIT=20

# ── Security ──────────────────────────────────────────────────────────────────
# Keep False until SSL is configured.
# Set True only when Nginx terminates HTTPS (and SECURE_PROXY_SSL_HEADER is set).
SECURE_SSL_REDIRECT=False

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Rule of thumb: (2 × CPU cores) + 1
GUNICORN_WORKERS=3
